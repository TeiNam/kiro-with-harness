{
  "version": 1,
  "target": "kiro",
  "modules": [
    {
      "id": "steering-global",
      "description": "Universal rules (always inclusion) — git workflow, work patterns, problem-solving approach. Applicable to any task: coding, writing, research",
      "sources": [
        { "from": "rules/common/git-workflow.md", "template": "steering-always" },
        { "from": "rules/common/patterns.md", "template": "steering-always" },
        { "from": "rules/common/performance.md", "template": "steering-always" }
      ],
      "outputDir": ".kiro/steering",
      "defaultInstall": false
    },
    {
      "id": "hooks-global",
      "description": "Universal Kiro hooks — post-task review, pre-write guard",
      "hooks": [
        { "id": "review-on-stop", "name": "Post-Task Review", "event": "agentStop", "action": "askAgent", "prompt": "Briefly review the completed work: 1) any security issues 2) proper error handling 3) no leftover console.log 4) tests needed for changes. Report issues only." },
        { "id": "pre-write-guard", "name": "Pre-Write Guard", "event": "preToolUse", "toolTypes": ["write"], "action": "askAgent", "prompt": "Before this write, check ALL of the following in one pass:\n1. SIZE — If the content exceeds 800 lines, BLOCK the write. Split into focused modules under 400 lines.\n2. SECRETS — No hardcoded API keys, tokens, passwords, or connection strings. Use env vars.\n3. DOC LOCATION — If creating a .md or .txt file outside docs/, .kiro/, README.md, CONTRIBUTING.md, CHANGELOG.md, or LICENSE, warn that docs should go in docs/.\nOnly report issues found. If all checks pass, proceed silently." }
      ],
      "outputDir": ".kiro/hooks",
      "defaultInstall": false
    },
    {
      "id": "steering-core",
      "description": "Common rules (always inclusion) — coding-style, security, testing, git-workflow, patterns, performance",
      "sources": [
        { "from": "rules/common/coding-style.md", "template": "steering-always" },
        { "from": "rules/common/security.md", "template": "steering-always", "merge": ["agents/security-reviewer.md", "skills/security-review/SKILL.md"] },
        { "from": "rules/common/testing.md", "template": "steering-always", "merge": ["agents/tdd-guide.md", "skills/tdd-workflow/SKILL.md"] },
        { "from": "rules/common/git-workflow.md", "template": "steering-always" },
        { "from": "rules/common/patterns.md", "template": "steering-always" },
        { "from": "rules/common/performance.md", "template": "steering-always" }
      ],
      "outputDir": ".kiro/steering",
      "defaultInstall": true
    },
    {
      "id": "steering-languages",
      "description": "Language-specific rules (fileMatch inclusion) — loaded only when matching files are opened",
      "sources": [
        { "from": "rules/typescript", "output": "typescript-rules.md", "fileMatch": "**/*.ts,**/*.tsx,**/*.js,**/*.jsx" },
        { "from": "rules/python", "output": "python-rules.md", "fileMatch": "**/*.py,**/*.pyi" },
        { "from": "rules/golang", "output": "golang-rules.md", "fileMatch": "**/*.go" },
        { "from": "rules/rust", "output": "rust-rules.md", "fileMatch": "**/*.rs" },
        { "from": "rules/java", "output": "java-rules.md", "fileMatch": "**/*.java" },
        { "from": "rules/kotlin", "output": "kotlin-rules.md", "fileMatch": "**/*.kt,**/*.kts" },
        { "from": "rules/swift", "output": "swift-rules.md", "fileMatch": "**/*.swift" },
        { "from": "rules/php", "output": "php-rules.md", "fileMatch": "**/*.php" },
        { "from": "rules/cpp", "output": "cpp-rules.md", "fileMatch": "**/*.cpp,**/*.hpp,**/*.cc,**/*.h,**/*.cxx" },
        { "from": "rules/csharp", "output": "csharp-rules.md", "fileMatch": "**/*.cs" },
        { "from": "rules/perl", "output": "perl-rules.md", "fileMatch": "**/*.pl,**/*.pm,**/*.t" }
      ],
      "outputDir": ".kiro/steering",
      "defaultInstall": false
    },
