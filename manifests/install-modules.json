    {
      "id": "hooks-core",
      "description": "Essential Kiro hooks — pre-write guard (security + size + doc location)",
      "hooks": [{ "id": "pre-write-guard", "name": "Pre-Write Guard", "event": "preToolUse", "toolTypes": ["write"], "action": "askAgent", "prompt": "Before this write, check ALL of the following in one pass:\n1. SIZE — If the content exceeds 800 lines, BLOCK the write. Split into focused modules under 400 lines.\n2. SECRETS — No hardcoded API keys, tokens, passwords, or connection strings. Use env vars.\n3. DOC LOCATION — If creating a .md or .txt file outside docs/, .kiro/, README.md, CONTRIBUTING.md, CHANGELOG.md, or LICENSE, warn that docs should go in docs/.\nOnly report issues found. If all checks pass, proceed silently." }],
      "outputDir": ".kiro/hooks",
      "defaultInstall": true
    },
    {
      "id": "hooks-quality",
      "description": "Quality Kiro hooks — lint, typecheck, code review, test",
      "hooks": [
        { "id": "diagnostics-on-save", "name": "Diagnostics After TS/JS Edit", "event": "fileEdited", "patterns": ["*.ts", "*.tsx", "*.js", "*.jsx"], "action": "askAgent", "prompt": "A TS/JS file was edited. Use getDiagnostics to check for lint errors and type errors in a single pass. Do NOT use executeBash or terminal — use getDiagnostics only. Report any issues found." },
        { "id": "review-on-stop", "name": "Post-Task Code Review", "event": "agentStop", "action": "askAgent", "prompt": "Briefly review the completed work: 1) any security issues 2) proper error handling 3) no leftover console.log 4) tests needed for changes. Report issues only." },
        { "id": "test-after-task", "name": "Test After Spec Task", "event": "postTaskExecution", "action": "askAgent", "prompt": "A spec task was completed. Remind the user to run tests manually in their terminal: npm test. Do NOT use executeBash or terminal to run tests directly — it may block or hang." }
      ],
      "outputDir": ".kiro/hooks",
      "defaultInstall": false
    },
    {
      "id": "hooks-guardrails",
